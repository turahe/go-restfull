# Copy to .env: cp .env.example .env — then add JWT_PRIVATE_KEY / JWT_PUBLIC_KEY (PEM).
# Defaults below match docker compose (service names as hostnames).
# For local `go run` without Docker: DB_HOST=127.0.0.1, REDIS_ADDR=127.0.0.1:6379 — media requires S3 or GCS (e.g. MINIO_* pointing at a dev MinIO).

APP_ENV=local
# Swagger UI at /swagger/index.html. Unset defaults to enabled only when APP_ENV=local; set SWAGGER_ENABLED=false to disable.
# SWAGGER_ENABLED=true
# Cloud Run sets PORT automatically; app will prefer PORT over SERVER_PORT.
SERVER_PORT=8080

# --- docker compose: mysql service ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=blog
MYSQL_USER=blog
MYSQL_PASSWORD=blog

# --- docker compose: minio service (S3 server) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Rate limiter (per-IP token bucket). Set to 0 to disable.
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10
RATE_LIMIT_KEY_PREFIX=rl:ip:

# Redis (required for redis-backed rate limiter)
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

DB_HOST=mysql
DB_PORT=3306

# MySQL driver mode:
# - mysql: connect to DB_HOST/DB_PORT over TCP
# - mysql-cloud: connect via Cloud SQL Go Connector (INSTANCE_CONNECTION_NAME)
DB_DRIVER=mysql
INSTANCE_CONNECTION_NAME=
# Set PRIVATE_IP=true to use Cloud SQL private IP (optional).
PRIVATE_IP=false
DB_USER=blog
DB_PASSWORD=blog
DB_NAME=blog

# JWT signing keys (required): PEM text for both (quoted multiline in .env). Generate with openssl, then paste PEM.
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ISSUER=go-rest-blog
JWT_AUDIENCE=blog-api
JWT_KEY_ID=k1

# Access tokens: 5-15 minutes (fintech style)
ACCESS_TOKEN_TTL_MINUTES=10

# Refresh token rotation
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_PEPPER=change_me_strong_secret

# Impersonation access token TTL (shorter)
IMPERSONATION_TTL_MINUTES=5

# Casbin RBAC
CASBIN_MODEL_PATH=configs/casbin_model.conf

# TOTP 2FA (AES-GCM encrypted secret storage)
TWO_FACTOR_ENC_KEY=0123456789abcdef0123456789abcdef
TWO_FACTOR_ISSUER=go-rest-blog

MEDIA_MAX_UPLOAD_BYTES=10485760

# Object storage (required): s3 (S3 API, including MinIO) or gcs.
# If MEDIA_STORAGE is unset, it is inferred: full S3 credentials -> s3; GCS_BUCKET only -> gcs.
# If both S3 and GCS are configured, set MEDIA_STORAGE explicitly.
MEDIA_STORAGE=s3

# S3-compatible (AWS S3, MinIO, etc.). For AWS set S3_REGION (e.g. us-east-1) and S3_USE_SSL=true.
# S3_ENDPOINT=s3.us-east-1.amazonaws.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_USE_SSL=true

# Legacy MinIO env names (merged into S3_* when S3_* are empty)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=media
MINIO_USE_SSL=false

# Google Cloud Storage (uses Application Default Credentials; set GOOGLE_APPLICATION_CREDENTIALS if needed)
# MEDIA_STORAGE=gcs
# GCS_BUCKET=your-bucket-name
