APP_ENV=local
SERVER_PORT=8080

# Rate limiter (per-IP token bucket). Set to 0 to disable.
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10
RATE_LIMIT_KEY_PREFIX=rl:ip:

# Redis (required for redis-backed rate limiter)
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

DB_HOST=127.0.0.1
DB_PORT=3306
# Local (docker-compose) defaults:
DB_USER=blog
DB_PASSWORD=blog
DB_NAME=blog

JWT_PRIVATE_KEY_PATH=keys/jwtRS256.key
JWT_PUBLIC_KEY_PATH=keys/jwtRS256.key.pub
JWT_ISSUER=go-rest-blog
JWT_AUDIENCE=blog-api
JWT_KEY_ID=k1

# Access tokens: 5-15 minutes (fintech style)
ACCESS_TOKEN_TTL_MINUTES=10

# Refresh token rotation
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_PEPPER=change_me_strong_secret

# Impersonation access token TTL (shorter)
IMPERSONATION_TTL_MINUTES=5

# Casbin RBAC
CASBIN_MODEL_PATH=configs/casbin_model.conf

# TOTP 2FA (AES-GCM encrypted secret storage)
TWO_FACTOR_ENC_KEY=0123456789abcdef0123456789abcdef
TWO_FACTOR_ISSUER=go-rest-blog

# Media uploads
MEDIA_UPLOAD_DIR=uploads
MEDIA_MAX_UPLOAD_BYTES=10485760

# MinIO (S3-compatible) media storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=media
MINIO_USE_SSL=false

